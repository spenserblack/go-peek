root = true

[*]
end_of_line = LF
charset = utf-8
trim_trailing_whitespace = true
insert_final_newline = true

# Go
[*.go]
indent_style = tab
indent_size = 4

# JSON (and with comments)
[*.{json,jsonc}]
indent_style = space
indent_size = 2

# Markdown
[*.md]
# Unset for easier control of tabs and spaces in code blocks
indent_style = unset
indent_size = unset

# Shell
[*.{sh,bash}]
indent_style = tab
indent_size = 2

# YAML
[*.{yml,yaml}]
indent_style = space
indent_size = 2
